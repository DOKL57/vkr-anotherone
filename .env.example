POSTGRES_DB=sound_rental
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/sound_rental?schema=public
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
HOST=0.0.0.0
PORT=3001
CORS_ORIGIN=http://localhost:5173
LOCAL_LLM_URL=http://host.docker.internal:1234/v1
LOCAL_LLM_MODEL=auto
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Cheapest option: OpenRouter free router. If API key is set, API uses this instead of local LLM.
OPENROUTER_MODEL=openrouter/free
API_URL=http://api:3001
BOT_LOCAL_API_URL=http://localhost:3001
VITE_API_PROXY_TARGET=http://api:3001
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_API_URL=https://api.telegram.org
# Local file for bot login sessions. Telegram does not provide this; bot creates it automatically.
TELEGRAM_BOT_SESSION_FILE=.runtime/telegram-bot-sessions.json
BOT_POLLING_INTERVAL=1000
