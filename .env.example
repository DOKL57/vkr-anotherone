POSTGRES_DB=sound_rental
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/sound_rental?schema=public
PORT=3001
CORS_ORIGIN=http://localhost:5173
LOCAL_LLM_URL=http://host.docker.internal:1234/v1
LOCAL_LLM_MODEL=local-model
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Cheapest option: OpenRouter free router. If API key is set, API uses this instead of local LLM.
OPENROUTER_MODEL=openrouter/free
API_URL=http://api:3001
# Put real token from @BotFather here.
TELEGRAM_BOT_TOKEN=replace_me
# For Telegram clients outside local machine use public HTTPS URL.
TELEGRAM_WEBAPP_URL=http://localhost:5173
TELEGRAM_AUTH_DATE_TOLERANCE_SEC=86400
